{
  "openapi": "3.0.0",
  "info": {
    "title": "Hotel Booking API",
    "description": "Contract between the Express backend and frontend",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter the JWT token in the format: Bearer <token>"
      }
    },
    "schemas": {
      "LoginResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "User logged in successfully"
          },
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsIn..."
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        },
        "required": [
          "message",
          "token",
          "user"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          },
          "firstName": {
            "type": "string",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          },
          "gender": {
            "type": "string",
            "example": "male"
          },
          "birthdate": {
            "type": "string",
            "example": "1995-05-15"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john.doe@example.com"
          },
          "specialOffer": {
            "type": "boolean"
          },
          "avatarUrl": {
            "type": "string",
            "example": "https://example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "example": "user"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "firstName",
          "lastName",
          "gender",
          "birthdate",
          "email",
          "specialOffer",
          "avatarUrl",
          "role",
          "createdAt",
          "updatedAt"
        ]
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Bad request"
          },
          "status": {
            "type": "string",
            "example": "fail"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "example": "checkOut"
                },
                "message": {
                  "type": "string",
                  "example": "Check-out date must be after check-in date"
                }
              },
              "required": [
                "field",
                "message"
              ]
            }
          }
        },
        "required": [
          "message",
          "status",
          "errors"
        ]
      },
      "BaseMessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Invalid credentials"
          }
        },
        "required": [
          "message"
        ]
      },
      "LoginRequestBody": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RegisterRequestBody": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "minLength": 1
          },
          "lastName": {
            "type": "string",
            "minLength": 1
          },
          "gender": {
            "type": "string",
            "minLength": 1
          },
          "birthdate": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "specialOffer": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "firstName",
          "lastName",
          "gender",
          "birthdate",
          "email",
          "password"
        ]
      },
      "PriceSummary": {
        "type": "object",
        "properties": {
          "nights": {
            "type": "number",
            "example": 6
          },
          "discount": {
            "type": "number",
            "example": 0
          },
          "pricePerNight": {
            "type": "number",
            "example": 5000
          },
          "basePrice": {
            "type": "number",
            "example": 30000
          },
          "servicePrice": {
            "type": "number",
            "example": 1000
          },
          "additionalServicePrice": {
            "type": "number",
            "example": 1500
          },
          "additionalServiceSummary": {
            "type": "object",
            "properties": {
              "dinner": {
                "type": "number"
              },
              "desk": {
                "type": "number"
              },
              "highchair": {
                "type": "number"
              },
              "crib": {
                "type": "number"
              },
              "TV": {
                "type": "number"
              },
              "shampoo": {
                "type": "number"
              }
            }
          },
          "totalPrice": {
            "type": "number",
            "example": 32500
          }
        },
        "required": [
          "nights",
          "discount",
          "pricePerNight",
          "basePrice",
          "servicePrice",
          "additionalServicePrice",
          "additionalServiceSummary",
          "totalPrice"
        ]
      },
      "BookingRequestBody": {
        "type": "object",
        "properties": {
          "checkIn": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-06T12:00:00.000Z"
          },
          "checkOut": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-06T12:00:00.000Z"
          },
          "additionalServices": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "dinner",
                "desk",
                "highchair",
                "crib",
                "TV",
                "shampoo"
              ]
            },
            "default": []
          },
          "guests": {
            "type": "object",
            "properties": {
              "adult": {
                "type": "number",
                "minimum": 0,
                "default": 0
              },
              "child": {
                "type": "number",
                "minimum": 0,
                "default": 0
              },
              "baby": {
                "type": "number",
                "minimum": 0,
                "default": 0
              }
            },
            "default": {
              "adult": 0,
              "child": 0,
              "baby": 0
            }
          }
        },
        "required": [
          "checkIn",
          "checkOut"
        ]
      },
      "Booking": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "MongoDB ObjectId virtual id",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          },
          "user": {
            "type": "string",
            "description": "User ObjectId ref",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          },
          "room": {
            "type": "string",
            "description": "Room ObjectId ref",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          },
          "checkIn": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-01T12:00:00.000Z"
          },
          "checkOut": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-07T12:00:00.000Z"
          },
          "guests": {
            "type": "object",
            "properties": {
              "adult": {
                "type": "number",
                "default": 0
              },
              "child": {
                "type": "number",
                "default": 0
              },
              "baby": {
                "type": "number",
                "default": 0
              }
            }
          },
          "additionalServices": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "dinner",
                "desk",
                "highchair",
                "crib",
                "TV",
                "shampoo"
              ]
            }
          },
          "priceSummary": {
            "$ref": "#/components/schemas/PriceSummary"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "user",
          "room",
          "checkIn",
          "checkOut",
          "guests",
          "additionalServices",
          "priceSummary",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateRatingRequestBody": {
        "type": "object",
        "properties": {
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": [
          "score"
        ]
      },
      "RatingSummary": {
        "type": "object",
        "properties": {
          "totalCount": {
            "type": "number",
            "example": 12
          },
          "avgScore": {
            "type": "number",
            "example": 4.5
          },
          "scoreBreakdown": {
            "type": "object",
            "properties": {
              "1": {
                "type": "number"
              },
              "2": {
                "type": "number"
              },
              "3": {
                "type": "number"
              },
              "4": {
                "type": "number"
              },
              "5": {
                "type": "number"
              }
            },
            "example": {
              "1": 0,
              "2": 1,
              "3": 2,
              "4": 4,
              "5": 5
            }
          }
        },
        "required": [
          "totalCount",
          "avgScore",
          "scoreBreakdown"
        ]
      },
      "CreateReviewRequestBody": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "roomId": {
            "type": "string",
            "description": "MongoDB ObjectId hex string",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          }
        },
        "required": [
          "text",
          "roomId"
        ]
      },
      "PaginatedReviews": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Review"
            }
          },
          "totalDocs": {
            "type": "number",
            "example": 42
          },
          "limit": {
            "type": "number",
            "example": 10
          },
          "page": {
            "type": "number",
            "example": 1
          },
          "totalPages": {
            "type": "number",
            "example": 5
          },
          "pagingCounter": {
            "type": "number",
            "example": 1
          },
          "hasPrevPage": {
            "type": "boolean"
          },
          "hasNextPage": {
            "type": "boolean"
          },
          "prevPage": {
            "type": "number",
            "nullable": true
          },
          "nextPage": {
            "type": "number",
            "nullable": true
          }
        },
        "required": [
          "docs",
          "totalDocs",
          "limit",
          "page",
          "totalPages",
          "pagingCounter",
          "hasPrevPage",
          "hasNextPage",
          "prevPage",
          "nextPage"
        ]
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          },
          "authorName": {
            "type": "string",
            "example": "Ivan Ivanov"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com"
          },
          "text": {
            "type": "string",
            "example": "Great room, very clean!"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "likeCount": {
            "type": "integer",
            "example": 5
          },
          "isLiked": {
            "type": "boolean",
            "description": "True if current user liked this review"
          }
        },
        "required": [
          "id",
          "authorName",
          "avatarUrl",
          "text",
          "createdAt",
          "likeCount",
          "isLiked"
        ]
      },
      "ToggleLikeResponse": {
        "type": "object",
        "properties": {
          "likeCount": {
            "type": "integer",
            "minimum": 0,
            "example": 6
          },
          "isLiked": {
            "type": "boolean",
            "description": "The new like status for the current user"
          }
        },
        "required": [
          "likeCount",
          "isLiked"
        ]
      },
      "PaginatedRooms": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Room"
            }
          },
          "totalDocs": {
            "type": "number",
            "example": 42
          },
          "limit": {
            "type": "number",
            "example": 10
          },
          "page": {
            "type": "number",
            "example": 1
          },
          "totalPages": {
            "type": "number",
            "example": 5
          },
          "pagingCounter": {
            "type": "number",
            "example": 1
          },
          "hasPrevPage": {
            "type": "boolean"
          },
          "hasNextPage": {
            "type": "boolean"
          },
          "prevPage": {
            "type": "number",
            "nullable": true
          },
          "nextPage": {
            "type": "number",
            "nullable": true
          }
        },
        "required": [
          "docs",
          "totalDocs",
          "limit",
          "page",
          "totalPages",
          "pagingCounter",
          "hasPrevPage",
          "hasNextPage",
          "prevPage",
          "nextPage"
        ]
      },
      "Room": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "5d7a4c2e8b1f6a390e4d2c1b"
          },
          "roomNumber": {
            "type": "number",
            "example": 840
          },
          "price": {
            "type": "number",
            "example": 5000
          },
          "capacity": {
            "type": "number",
            "example": 4
          },
          "bed": {
            "type": "number",
            "example": 2
          },
          "bedroom": {
            "type": "number",
            "example": 1
          },
          "bathroom": {
            "type": "number",
            "example": 1
          },
          "isAvailable": {
            "type": "boolean"
          },
          "avgRating": {
            "type": "number",
            "example": 4.5
          },
          "reviewsCount": {
            "type": "number",
            "example": 12
          },
          "accessibility": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "wideCorridor",
                "assistant"
              ]
            }
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "smokeAllowed",
                "petsAllowed",
                "guestsAllowed"
              ]
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "roomNumber",
          "price",
          "capacity",
          "bed",
          "bedroom",
          "bathroom",
          "isAvailable",
          "avgRating",
          "reviewsCount",
          "accessibility",
          "rules",
          "createdAt",
          "updatedAt"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Authenticate user and get token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User authenticated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Email already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/bookings/{roomId}/preview": {
      "post": {
        "summary": "Get booking price preview",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "MongoDB ObjectId hex string",
              "example": "5d7a4c2e8b1f6a390e4d2c1b"
            },
            "required": true,
            "description": "MongoDB ObjectId hex string",
            "name": "roomId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookingRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Price preview calculated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceSummary"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Room not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/bookings/{roomId}/confirm": {
      "post": {
        "summary": "Confirm and create room booking",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "MongoDB ObjectId hex string",
              "example": "5d7a4c2e8b1f6a390e4d2c1b"
            },
            "required": true,
            "description": "MongoDB ObjectId hex string",
            "name": "roomId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookingRequestBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Booking created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Booking"
                }
              }
            }
          },
          "400": {
            "description": "Validation or overlapping error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "404": {
            "description": "Room not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ratings/{roomId}": {
      "post": {
        "summary": "Create or update room rating",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "MongoDB ObjectId hex string",
              "example": "5d7a4c2e8b1f6a390e4d2c1b"
            },
            "required": true,
            "description": "MongoDB ObjectId hex string",
            "name": "roomId",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRatingRequestBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Rating saved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access",
            "content": {
              "application/json": {
                "schema": {
