    "/api/v1/rooms/search": {
      "get": {
        "summary": "Search for available rooms based on criteria",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2026-06-06T12:00:00.000Z"
            },
            "required": true,
            "name": "checkIn",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2026-06-06T12:00:00.000Z"
            },
            "required": true,
            "name": "checkOut",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 0
            },
            "required": false,
            "name": "minPrice",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 0
            },
            "required": false,
            "name": "maxPrice",
            "in": "query"
          },
          {
            "schema": {
              "type": "object",
              "properties": {
                "adult": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                },
                "child": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                },
                "baby": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                }
              },
              "default": {
                "adult": 0,
                "child": 0,
                "baby": 0
              }
            },
            "required": false,
            "name": "guests",
            "in": "query"
          },
          {
            "schema": {
              "type": "object",
              "properties": {
                "bed": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                },
                "bedroom": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                },
                "bathroom": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                }
              },
              "default": {
                "bed": 0,
                "bedroom": 0,
                "bathroom": 0
              }
            },
            "required": false,
            "name": "amenities",
            "in": "query"
          },
          {
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "wideCorridor",
                  "assistant"
                ]
              },
              "default": []
            },
            "required": false,
            "name": "accessibility",
            "in": "query"
          },
          {
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "smokeAllowed",
                  "petsAllowed",
                  "guestsAllowed"
                ]
              },
              "default": []
            },
            "required": false,
            "name": "rules",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "price",
                "roomNumber",
                "avgRating",
                "reviewsCount",
                "createAt"
              ],
              "default": "createAt"
            },
            "required": false,
            "name": "sort",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "default": 1,
              "description": "1 for ASC, -1 for DESC",
              "example": 1
            },
            "required": false,
            "description": "1 for ASC, -1 for DESC",
            "name": "order",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 0,
              "exclusiveMinimum": true,
              "default": 12
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 0,
              "exclusiveMinimum": true,
              "default": 1
            },
            "required": false,
            "name": "page",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated available rooms list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedRooms"
                }
              }
            }
          },
          "400": {
            "description": "Validation error or incorrect date range",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseMessageResponse"
                }
              }
            }
          }
        }
      }
    },
